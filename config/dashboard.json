{
  "display": {
    "refresh_rate": 4,
    "log_buffer_size": 8,
    "theme": "default",
    "show_sparkline": true,
    "cost_timeline_minutes": 60
  },
  "behavior": {
    "auto_clear_completed": false,
    "auto_check_new_interval_seconds": 0,
    "pause_on_error": false,
    "max_retries": 3
  },
  "cost": {
    "warning_threshold_per_hour": 10.0,
    "alert_threshold_per_project": 1.0,
    "show_estimates": true
  },
  "keyboard": {
    "pause": "p",
    "skip": "s",
    "retry": "r",
    "errors": "e",
    "remove": "x",
    "restart": "d",
    "logs": "l",
    "export": "t",
    "quit": "q",
    "clear": "c",
    "new": "n"
  }
}
