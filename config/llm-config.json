{
  "primary_backend": "openai-mini",
  "fallback_backend": "openai",

  "backends": {
    "local-ollama": {
      "type": "ollama",
      "endpoint": "http://localhost:11434",
      "model": "qwen2.5:14b",
      "timeout": 180,
      "cost_per_project": 0.00,
      "enabled": false
    },
    "remote-ollama": {
      "type": "ollama",
      "endpoint": "http://192.168.1.100:11434",
      "model": "qwen2.5:14b",
      "timeout": 180,
      "cost_per_project": 0.00,
      "enabled": false
    },
    "openai-mini": {
      "type": "openai",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o-mini",
      "api_key_env": "OPENAI_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.012
    },
    "openai": {
      "type": "openai",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.20
    },
    "claude": {
      "type": "anthropic",
      "endpoint": "https://api.anthropic.com/v1/messages",
      "model": "claude-3-5-sonnet-latest",
      "api_key_env": "ANTHROPIC_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.25
    }
  },

  "auto_select": {
    "enabled": false,
    "preference_order": [
      "openai-mini",
      "openai",
      "claude"
    ],
    "check_interval_seconds": 5
  },

  "processing": {
    "check_queue_interval_seconds": 300,
    "batch_size": 4,
    "parallel_processing": false
  }
}